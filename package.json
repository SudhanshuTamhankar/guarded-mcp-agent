{
  "name": "guarded-mcp-agent",
  "private": true,
  "workspaces": [
    "apps/*",
    "mcp-servers/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=api\" \"npm run dev --workspace=web\"",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start --workspace=api"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}