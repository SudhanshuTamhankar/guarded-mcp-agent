[
  {
    "type": "BLOCK_TOOL",
    "name": "Block sandbox delete_file",
    "enabled": true,
    "serverId": "sandbox-files",
    "toolName": "delete_file",
    "config": {
      "reason": "delete_file is destructive and blocked by default"
    }
  },
  {
    "type": "REQUIRE_APPROVAL",
    "name": "Require approval for sandbox write_file",
    "enabled": true,
    "serverId": "sandbox-files",
    "toolName": "write_file",
    "config": {
      "approvalTtlSeconds": 120,
      "reason": "write_file mutates sandbox state"
    }
  },
  {
    "type": "PATH_ALLOWLIST",
    "name": "Restrict sandbox paths",
    "enabled": true,
    "serverId": "sandbox-files",
    "toolName": "*",
    "config": {
      "argumentNames": ["path"],
      "allowedPrefix": "/sandbox/"
    }
  },
  {
    "type": "MAX_TOOL_CALLS",
    "name": "Limit tool calls per conversation",
    "enabled": true,
    "serverId": "*",
    "toolName": "*",
    "config": {
      "maxToolCalls": 8
    }
  },
  {
    "type": "PROMPT_INJECTION_GUARD",
    "name": "Detect prompt injection in user/tool content",
    "enabled": true,
    "serverId": "*",
    "toolName": "*",
    "config": {
      "mode": "sanitize_and_log",
      "blockHighRiskDangerousFollowups": true
    }
  },
  {
    "type": "SECRET_REDACTION",
    "name": "Redact secrets from logs and outputs",
    "enabled": true,
    "serverId": "*",
    "toolName": "*",
    "config": {
      "redactLogs": true,
      "redactToolOutputs": true
    }
  }
]
